rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthed() && request.auth.token.email == 'ads.cesaralves@gmail.com';
    }

    function isGlobalAdmin() {
      return isAuthed() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/config/admins) &&
         request.auth.token.email in
           get(/databases/$(database)/documents/config/admins).data.get('emails', []))
      );
    }

    function isChurchDirector(churchId) {
      return isAuthed() &&
        exists(/databases/$(database)/documents/churches/$(churchId)) &&
        get(/databases/$(database)/documents/churches/$(churchId)).data.get('directorUid', '') == request.auth.uid;
    }

    // Pode editar dados de uma igreja específica
    function canWriteChurch(churchId) {
      return isSuperAdmin() || isChurchDirector(churchId) || isGlobalAdmin();
    }

    // ── Usuários ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // ── Igrejas (documento raiz) ───────────────────────────────────────────
    match /churches/{churchId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if canWriteChurch(churchId);

      // ── Músicas, Cifras, Eventos: só admins da igreja escrevem ────────────
      match /songs/{docId} {
        allow read: if isAuthed();
        allow write: if canWriteChurch(churchId);
      }
      match /cifras/{docId} {
        allow read: if isAuthed();
        allow write: if canWriteChurch(churchId);
      }
      match /eventos/{docId} {
        allow read: if isAuthed();
        allow write: if canWriteChurch(churchId);
      }

      // ── Membros: qualquer autenticado lê/cria, admin deleta ───────────────
      match /membros/{docId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow update, delete: if canWriteChurch(churchId);
      }

      // ── Confirmações de presença: qualquer membro gerencia a própria ───────
      match /confirmacoes/{docId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow update, delete: if isAuthed() && (
          request.auth.uid == resource.data.get('userId', '') ||
          canWriteChurch(churchId)
        );
      }

      // ── Sorteio/oração: qualquer autenticado ─────────────────────────────
      match /sorteios/{docId} {
        allow read, write: if isAuthed();
      }

      // Fallback para qualquer subcoleção não mapeada acima
      match /{subcol}/{docId} {
        allow read: if isAuthed();
        allow write: if canWriteChurch(churchId);
      }
    }

    // ── collectionGroup: songs e cifras (necessário para aba "Para Você") ────
    // Firestore exige regra com wildcard recursivo para queries collectionGroup
    match /{path=**}/songs/{docId} {
      allow read: if isAuthed();
    }
    match /{path=**}/cifras/{docId} {
      allow read: if isAuthed();
    }

    // ── Solicitações de troca de igreja ───────────────────────────────────────
    match /churchJoinRequests/{reqId} {
      allow read: if isAuthed() && (
        request.auth.uid == resource.data.get('fromUid', '') ||
        isChurchDirector(resource.data.get('toChurchId', '')) ||
        isGlobalAdmin()
      );
      allow create: if isAuthed() && request.auth.uid == request.resource.data.get('fromUid', '');
      allow update: if isAuthed() && (
        isChurchDirector(resource.data.get('toChurchId', '')) ||
        isGlobalAdmin()
      );
    }

    // ── Feed global ───────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read, write: if isAuthed();
    }

    // ── Coleções legadas (compatibilidade) ────────────────────────────────────
    match /eventos/{eventoId} {
      allow read, write: if isAuthed();
    }
    match /confirmacoes/{id} {
      allow read, write: if isAuthed();
    }
    match /sorteios/{id} {
      allow read, write: if isAuthed();
    }
    match /membros/{id} {
      allow read, write: if isAuthed();
    }
    match /songs/{id} {
      allow read, write: if isAuthed();
    }
    match /cifras/{id} {
      allow read, write: if isAuthed();
    }
    match /follows/{id} {
      allow read, write: if isAuthed();
    }
    match /notifications/{id} {
      allow read, write: if isAuthed();
    }
    match /config/{id} {
      allow read: if isAuthed();
      allow write: if isGlobalAdmin();
    }

    // ── Comunhão global ───────────────────────────────────────────────────────
    match /comunhao/{id} {
      allow read, write: if isAuthed();
    }

    // ── Conversas privadas ────────────────────────────────────────────────────
    match /conversations/{convId} {
      // resource == null quando o documento não existe (getDoc em conversa nova)
      allow read: if isAuthed() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isAuthed() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthed() &&
        request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuthed() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthed() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthed() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow delete: if false;
      }
    }
  }
}

